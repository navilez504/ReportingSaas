# Copy to .env.production and fill in real values (never commit .env.production).
# Run: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d --build

SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=https://example.com,https://www.example.com
VITE_API_URL=https://example.com

# Admins (comma-separated). These emails get admin role on register/login.
ADMIN_EMAILS=you@company.com

# Public browser URL for Stripe Checkout return (no trailing slash)
PUBLIC_APP_URL=https://example.com

# Stripe (optional until you go live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Outbound email (Gmail: use an App Password with 2-Step Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Internal Postgres container credentials used by docker-compose.prod.yml
POSTGRES_USER=reporting
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=reporting_db

# Optional: AWS RDS or other external DB — use a compose override that sets DATABASE_URL on the backend
# service. For the default stack (Postgres container), leave DATABASE_URL unset; docker-compose.prod.yml
# builds the URL from POSTGRES_* + host "postgres".
# DATABASE_URL=postgresql://user:password@db-host:5432/reporting_db
