SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=https://example.com,https://www.example.com
VITE_API_URL=https://example.com

# Internal Postgres container credentials used by docker-compose.prod.yml
POSTGRES_USER=reporting
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=reporting_db

# Optional override if you use an external database like AWS RDS.
# DATABASE_URL=postgresql://user:password@db-host:5432/reporting_db
