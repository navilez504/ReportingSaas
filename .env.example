# Backend (also used by docker-compose for backend service)
SECRET_KEY=generate-with-openssl-rand-hex-32
DATABASE_URL=postgresql://reporting:reporting@localhost:5432/reporting_db
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_UPLOAD_MB=25
DEBUG=false

# WHO IS ADMIN: comma-separated emails (case-insensitive). There is no “first user is admin” rule.
# These accounts get admin on register, on login, on GET /api/users/me, and on backend startup.
# Example: ADMIN_EMAILS=you@company.com,coworker@company.com
ADMIN_EMAILS=admin@example.com

# Stripe (Checkout + Customer Portal + webhooks). Price IDs from Dashboard → Products → Price API ID.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Browser-visible app URL for Checkout/Portal return URLs (no trailing slash).
# Local Vite: http://localhost:5173
# Docker Compose (frontend on port 80): http://localhost
PUBLIC_APP_URL=http://localhost:5173

# --- Outbound email (trial ending, file limit, payment confirmation) ---
# Leave SMTP_HOST empty to only log email bodies (no sending) — fine for local dev.
#
# From your mail provider, you need:
#   SMTP_HOST      — SMTP server hostname (e.g. smtp.sendgrid.net, smtp.gmail.com)
#   SMTP_PORT      — usually 587 with STARTTLS (default below)
#   SMTP_USER      — username (often the full email for Gmail; or "apikey" for SendGrid)
#   SMTP_PASSWORD  — password or app-specific password / API key (never commit real values)
#   SMTP_FROM      — sender address users see (must be verified/allowed with the provider)
#   SMTP_USE_TLS   — true = STARTTLS after connect (typical for port 587)
#
# The backend uses STARTTLS on the given port (not implicit SSL on 465). Use the settings your
# provider documents for "SMTP" or "transactional" mail.
#
# Gmail: enable 2-Step Verification → create an App Password. Use SMTP_HOST=smtp.gmail.com,
# port 587, SMTP_USER=your address, SMTP_FROM same as SMTP_USER (unless you use a verified alias).

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
# Set true + port 465 only if your provider requires implicit SSL (not Gmail 587).
SMTP_USE_SSL=false

# Frontend: leave empty so the app calls /api on the same origin (Docker nginx or Vite dev proxy → API).
# Set to a full URL (no trailing slash) only if the UI is hosted separately from the API, e.g. https://api.example.com
VITE_API_URL=
